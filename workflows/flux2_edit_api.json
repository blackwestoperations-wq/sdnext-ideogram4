{
  "_comment": "Flux 2 Dev Image Edit. Pre-upload reference image via /upload/image OR place in /comfyui/input/. In n8n inject filename into node 1, prompt into node 8.",
  "1": {
    "inputs": { "image": "reference.png" },
    "class_type": "LoadImage",
    "_meta": { "title": "Load Reference Image" }
  },
  "2": {
    "inputs": { "image": ["1", 0], "upscale_method": "lanczos", "megapixels": 1.0, "lock_ratio": 1 },
    "class_type": "ImageScaleToTotalPixels",
    "_meta": { "title": "ImageScaleToTotalPixels" }
  },
  "3": {
    "inputs": { "image": ["2", 0] },
    "class_type": "GetImageSize",
    "_meta": { "title": "GetImageSize" }
  },
  "4": {
    "inputs": { "vae_name": "full_encoder_small_decoder.safetensors" },
    "class_type": "VAELoader",
    "_meta": { "title": "Load VAE" }
  },
  "5": {
    "inputs": { "pixels": ["2", 0], "vae": ["4", 0] },
    "class_type": "VAEEncode",
    "_meta": { "title": "VAE Encode Reference" }
  },
  "6": {
    "inputs": { "clip_name": "mistral_3_small_flux2_bf16.safetensors", "type": "flux2", "device": "default" },
    "class_type": "CLIPLoader",
    "_meta": { "title": "Load CLIP" }
  },
  "7": {
    "inputs": { "unet_name": "flux2_dev_fp8mixed.safetensors", "weight_dtype": "default" },
    "class_type": "UNETLoader",
    "_meta": { "title": "Load Diffusion Model" }
  },
  "8": {
    "inputs": { "text": "Edit the woman to wear a small pale yellow knitted beanie with FLUX.2 COMFY patch", "clip": ["6", 0] },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "CLIP Text Encode (Prompt)" }
  },
  "9": {
    "inputs": { "guidance": 4, "conditioning": ["8", 0] },
    "class_type": "FluxGuidance",
    "_meta": { "title": "FluxGuidance" }
  },
  "10": {
    "inputs": { "conditioning": ["9", 0], "latent": ["5", 0] },
    "class_type": "ReferenceLatent",
    "_meta": { "title": "ReferenceLatent" }
  },
  "11": {
    "inputs": { "model": ["7", 0], "conditioning": ["10", 0] },
    "class_type": "BasicGuider",
    "_meta": { "title": "BasicGuider" }
  },
  "12": {
    "inputs": { "width": ["3", 0], "height": ["3", 1], "batch_size": 1 },
    "class_type": "EmptyFlux2LatentImage",
    "_meta": { "title": "Empty Latent Image" }
  },
  "13": {
    "inputs": { "steps": 20, "width": ["3", 0], "height": ["3", 1] },
    "class_type": "Flux2Scheduler",
    "_meta": { "title": "Flux2Scheduler" }
  },
  "14": {
    "inputs": { "noise_seed": 987654321, "control_after_generate": "randomize" },
    "class_type": "RandomNoise",
    "_meta": { "title": "Random Noise" }
  },
  "15": {
    "inputs": { "sampler_name": "euler" },
    "class_type": "KSamplerSelect",
    "_meta": { "title": "Sampler Select" }
  },
  "16": {
    "inputs": { "noise": ["14", 0], "guider": ["11", 0], "sampler": ["15", 0], "sigmas": ["13", 0], "latent_image": ["12", 0] },
    "class_type": "SamplerCustomAdvanced",
    "_meta": { "title": "Sampler" }
  },
  "17": {
    "inputs": { "samples": ["16", 0], "vae": ["4", 0] },
    "class_type": "VAEDecode",
    "_meta": { "title": "VAE Decode" }
  },
  "18": {
    "inputs": { "images": ["17", 0], "filename_prefix": "Flux2_Edit" },
    "class_type": "SaveImage",
    "_meta": { "title": "Save Image" }
  }
}
