{
  "_comment": "Flux 2 Dev Text-to-Image (no reference image). In n8n inject 'prompt' into node 4, width/height into node 6, seed into node 7.",
  "1": {
    "inputs": { "vae_name": "flux2-vae.safetensors" },
    "class_type": "VAELoader",
    "_meta": { "title": "Load VAE" }
  },
  "2": {
    "inputs": { "unet_name": "flux2_dev_fp8mixed.safetensors", "weight_dtype": "default" },
    "class_type": "UNETLoader",
    "_meta": { "title": "Load Diffusion Model" }
  },
  "3": {
    "inputs": { "clip_name": "mistral_3_small_flux2_bf16.safetensors", "type": "flux2", "device": "default" },
    "class_type": "CLIPLoader",
    "_meta": { "title": "Load CLIP" }
  },
  "4": {
    "inputs": { "text": "Luxury editorial product shot, midnight blue background, gold foil accents", "clip": ["3", 0] },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "CLIP Text Encode (Prompt)" }
  },
  "5": {
    "inputs": { "guidance": 3.5, "conditioning": ["4", 0] },
    "class_type": "FluxGuidance",
    "_meta": { "title": "FluxGuidance" }
  },
  "6": {
    "inputs": { "width": 1024, "height": 1024, "batch_size": 1 },
    "class_type": "EmptyFlux2LatentImage",
    "_meta": { "title": "Empty Latent Image" }
  },
  "7": {
    "inputs": { "noise_seed": 123456789, "control_after_generate": "randomize" },
    "class_type": "RandomNoise",
    "_meta": { "title": "Random Noise" }
  },
  "8": {
    "inputs": { "steps": 20, "width": 1024, "height": 1024 },
    "class_type": "Flux2Scheduler",
    "_meta": { "title": "Flux2Scheduler" }
  },
  "9": {
    "inputs": { "sampler_name": "euler" },
    "class_type": "KSamplerSelect",
    "_meta": { "title": "Sampler Select" }
  },
  "10": {
    "inputs": { "model": ["2", 0], "conditioning": ["5", 0] },
    "class_type": "BasicGuider",
    "_meta": { "title": "BasicGuider" }
  },
  "11": {
    "inputs": {
      "noise": ["7", 0],
      "guider": ["10", 0],
      "sampler": ["9", 0],
      "sigmas": ["8", 0],
      "latent_image": ["6", 0]
    },
    "class_type": "SamplerCustomAdvanced",
    "_meta": { "title": "Sampler" }
  },
  "12": {
    "inputs": { "samples": ["11", 0], "vae": ["1", 0] },
    "class_type": "VAEDecode",
    "_meta": { "title": "VAE Decode" }
  },
  "13": {
    "inputs": { "images": ["12", 0], "filename_prefix": "Flux2_T2I" },
    "class_type": "SaveImage",
    "_meta": { "title": "Save Image" }
  }
}
